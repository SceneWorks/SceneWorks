{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sceneworks.local/schemas/character.schema.json",
  "title": "SceneWorks Character",
  "type": "object",
  "required": ["schemaVersion", "id", "projectId", "name", "type", "createdAt", "updatedAt", "status"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "pattern": "^character_[a-z0-9_]+$" },
    "projectId": { "type": "string", "pattern": "^project_[a-z0-9_]+$" },
    "name": { "type": "string", "minLength": 1 },
    "type": { "enum": ["person", "creature", "object"] },
    "description": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "status": {
      "type": "object",
      "required": ["archived"],
      "properties": {
        "archived": { "type": "boolean" }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["assetId", "approved", "role", "addedAt"],
        "properties": {
          "assetId": { "type": "string" },
          "approved": { "type": "boolean" },
          "role": { "type": "string" },
          "notes": { "type": "string" },
          "addedAt": { "type": "string", "format": "date-time" },
          "approvedAt": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    },
    "looks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "approvedReferenceIds", "recipeSettings", "createdAt", "updatedAt"],
        "properties": {
          "id": { "type": "string", "pattern": "^look_[a-z0-9_]+$" },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "approvedReferenceIds": { "type": "array", "items": { "type": "string" } },
          "recipeSettings": { "type": "object" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "loras": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "scope", "compatibility", "createdAt", "updatedAt"],
        "properties": {
          "id": { "type": "string", "pattern": "^character_lora_[a-z0-9_]+$" },
          "loraId": { "type": ["string", "null"] },
          "name": { "type": "string", "minLength": 1 },
          "sourcePath": { "type": ["string", "null"] },
          "projectPath": { "type": ["string", "null"] },
          "copiedIntoProject": { "type": "boolean" },
          "category": { "const": "character" },
          "scope": { "enum": ["project", "global", "external"] },
          "triggerWords": { "type": "array", "items": { "type": "string" } },
          "defaultWeight": { "type": "number" },
          "compatibility": { "type": "object" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "trainedLoras": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
