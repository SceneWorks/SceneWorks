{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sceneworks.local/schemas/lora-manifest.schema.json",
  "title": "SceneWorks LoRA Manifest",
  "type": "object",
  "required": ["schemaVersion", "loras"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "loras": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "triggerWords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Activation keywords that make the LoRA work."
          },
          "notes": {
            "type": "string",
            "description": "Free-text usage guidance a keyword list can't capture (how to combine keywords, recommended weights, etc.)."
          },
          "icLora": { "type": "boolean" },
          "conditioningRole": {
            "type": "string",
            "enum": ["ic_lora"]
          }
        },
        "additionalProperties": true
      }
    }
  }
}
